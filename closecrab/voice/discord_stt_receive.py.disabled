# ─── voice receive 相关 monkey-patch (原在 maybe_start_discord_voice_sidecar._run) ──
# 复活时在 sidecar 线程启动 loop 前调一次 _install_receive_monkeypatches()。
# 这些只在「接收链路」需要; 纯 TTS 播报不需要, 故从 sidecar 主路径移除。
def _install_receive_monkeypatches():
    """安装 voice receive 所需的两组 monkey-patch:
    ① 诊断探针 (speaking/op/_add_ssrc 日志, 定位 hits=0 根因);
    ② opus 坏包容错 (corrupted stream 不再杀死整个录音)。
    """
    import discord

    # 诊断探针: monkey-patch voice gateway 收帧 + ssrc 填充, 定位 hits=0 根因
    # (① Discord 没发 speaking op5 / ② 发了但 _add_ssrc 没被调)。
    try:
        from discord.voice.gateway import VoiceWebSocket, OpCodes
        _known_ops = {int(getattr(OpCodes, n)) for n in (
            "ready", "heartbeat_ack", "resumed", "session_description", "hello")}
        _orig_recv = VoiceWebSocket.received_message

        async def _probe_recv(self, msg, /):
            try:
                _op = msg.get("op")
                if _op == int(OpCodes.speaking):
                    log.info("📡 收到 speaking(op5): d=%s", msg.get("d"))
                elif _op == int(OpCodes.clients_connect):
                    log.info("📡 收到 clients_connect: d=%s", msg.get("d"))
                elif _op not in _known_ops and _op < 12:
                    log.info("📡 收到 op=%s d=%s", _op, msg.get("d"))
            except Exception:
                pass
            return await _orig_recv(self, msg)

        VoiceWebSocket.received_message = _probe_recv

        _orig_add = discord.VoiceClient._add_ssrc

        def _probe_add(self, user_id, ssrc):
            log.info("✅ _add_ssrc: user=%s ssrc=%s", user_id, ssrc)
            return _orig_add(self, user_id, ssrc)

        discord.VoiceClient._add_ssrc = _probe_add
        log.info("voice 诊断探针已挂载 (speaking/op/_add_ssrc)")
    except Exception:
        log.exception("voice 诊断探针挂载失败")

    # 关键修复: opus 解码坏包容错。py-cord 的 PacketRouter 线程一遇 OpusError
    # ("corrupted stream"，多来自 ssrc 映射建立前喂进的密文包) 就在 run() 的
    # except 里 client.stop_recording() 杀死整个录音。_process_packet 是 router
    # loop 取数据的唯一入口，返回 None 会被 _do_run 跳过 (if data is not None:
    # sink.write)。catch 解码异常返回 None = 静默丢坏包、录音存活，好包继续累积
    # 到静音阈值，STT 才有机会出文字。
    try:
        from discord.opus import PacketDecoder, OpusError
        _orig_proc = PacketDecoder._process_packet

        def _safe_process(self, packet):
            try:
                return _orig_proc(self, packet)
            except OpusError as e:
                log.debug("丢弃 opus 坏包(corrupted)，录音继续: %s", e)
                return None
            except Exception as e:
                log.debug("丢弃坏包(解码异常)，录音继续: %s", e)
                return None

        PacketDecoder._process_packet = _safe_process
        log.info("opus 坏包容错已挂载 (corrupted 不再杀死录音)")
    except Exception:
        log.exception("opus 坏包容错挂载失败")
