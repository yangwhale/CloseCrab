{
  "$schema": "https://app.kilo.ai/config.json",
  "provider": {
    "google-vertex": {
      "options": {
        "project": "${ANTHROPIC_VERTEX_PROJECT_ID}",
        "location": "global",
        "providerOptions": {
          "thinkingConfig": {
            "thinkingLevel": "low",
            "includeThoughts": false
          }
        }
      }
    },
    "google-vertex-anthropic": {
      "options": {
        "project": "${ANTHROPIC_VERTEX_PROJECT_ID}",
        "location": "global"
      }
    }
  },
  "permission": {
    "*": "allow",
    "bash": "allow"
  },
  "mcp": {
    "jina-ai": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "jina-ai-mcp-server"
      ],
      "environment": {
        "JINA_API_KEY": "${JINA_API_KEY}"
      }
    },
    "wiki": {
      "type": "local",
      "command": [
        "python3",
        "${HOME}/my-wiki-v2/scripts/wiki-mcp-server.py"
      ]
    }
  },
  "model": "google-vertex-anthropic/claude-opus-4-7@default",
  "small_model": "google-vertex-anthropic/claude-sonnet-4-6",
  "compaction": {
    "auto": true,
    "prune": true
  }
}
